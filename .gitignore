# =============================================================================
# SafeTool PDF — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
*.whl
*.tar.gz
*.zip
.eggs/
pip-log.txt
pip-delete-this-directory.txt

# Virtual environments
.venv/
venv/
ENV/
env/

# ---------------------------------------------------------------------------
# IDE / editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ---------------------------------------------------------------------------
# OS files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ---------------------------------------------------------------------------
# Testing
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.log

# Test-generated PDFs 
tests/test_pdfs/generated/

# ---------------------------------------------------------------------------
# Packaging — build artefacts
# ---------------------------------------------------------------------------
# PyInstaller
*.spec.bak
packaging/pyinstaller/build/
packaging/pyinstaller/dist/

# Nuitka
packaging/nuitka/*.build/
packaging/nuitka/*.dist/
packaging/nuitka/*.onefile-build/

# AppImage
*.AppImage
packaging/linux/appimage/*.AppDir/

# Flatpak
packaging/linux/flatpak/.flatpak-builder/
packaging/linux/flatpak/builddir/
*.flatpak

# macOS
*.app/
*.dmg

# Windows
*.exe
packaging/windows/Output/

# ---------------------------------------------------------------------------
# Vendored binaries (downloaded, not committed)
# ---------------------------------------------------------------------------
packaging/vendor/gs/
!packaging/vendor/.gitkeep

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
*.bak
*.tmp
*.temp
*.orig
*.rej
*.patch
.mypy_cache/
.ruff_cache/
.pytype/
